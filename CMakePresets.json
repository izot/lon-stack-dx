{
    "version": 6,
    "configurePresets": [
        {
            "name": "arm64-cross",
            "description": "Build using 64-bit ARM cross toolchain",
            "hidden": false,
            "generator": "Ninja",
            "toolchainFile": "${sourceDir}/aarch64-toolchain.cmake",
            "binaryDir": "${sourceDir}/build/arm64",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_INSTALL_DO_STRIP": "OFF",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "OS_ID": "OS_ID_LINUX",
                "PLATFORM_ID": "PLATFORM_ID_LINUX64_ARM_GCC",
                "PROCESSOR_ID": "PROCESSOR_ID_ARM64"
            }
        },
        {
            "name": "stm32-cortex-m4-cross",
            "description": "Build using ARM cross toolchain for STM32 Cortex-M4",
            "hidden": false,
            "generator": "Ninja",
            "toolchainFile": "${sourceDir}/arm-cortex-m4-toolchain.cmake",
            "binaryDir": "${sourceDir}/build/stm32-cortex-m4",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_INSTALL_DO_STRIP": "OFF",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "OS_ID": "OS_ID_FREERTOS",
                "PLATFORM_ID": "PLATFORM_ID_FRTOS_ARM_EABI",
                "PROCESSOR_ID": "PROCESSOR_ID_STM32"
            }
        },
        {
            "name": "default",
            "description": "Default build using native compiler",
            "hidden": false,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/default",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "arm64-cross",
            "displayName": "ARM64 cross (build Example1)",
            "configurePreset": "arm64-cross",
            "targets": [
                "lon_stack_example1"
            ]
        },
        {
            "name": "stm32-cortex-m4-cross",
            "displayName": "STM32 Cortex-M4 cross (build Example1)",
            "configurePreset": "stm32-cortex-m4-cross",
            "targets": [
                "lon_stack_example1"
            ]
        },
        {
            "name": "default",
            "displayName": "Native (build Example1)",
            "configurePreset": "default",
            "targets": [
                "lon_stack_example1"
            ]
        }
    ]
}