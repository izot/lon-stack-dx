{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Example1 on home-control (gdbserver)",
      "type": "cppdbg",
      "request": "launch",
      "MIMode": "gdb",
      "targetArchitecture": "arm64",
      "miDebuggerPath": "/opt/homebrew/bin/aarch64-linux-gnu-gdb",
      "program": "${workspaceFolder}/build/arm64/lon_stack_example1",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "preLaunchTask": "Start gdbserver on home-control (Example1)",
      "miDebuggerServerAddress": "localhost:2345",
      "setupCommands": [
        {
          "description": "Enable pretty-printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    },
    {
      "name": "Debug Example1 on home-lab (gdbserver)",
      "type": "cppdbg",
      "request": "launch",
      "MIMode": "gdb",
      "targetArchitecture": "arm64",
      "miDebuggerPath": "/opt/homebrew/bin/aarch64-linux-gnu-gdb",
      "program": "${workspaceFolder}/build/arm64/lon_stack_example1",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "preLaunchTask": "Start gdbserver on home-lab (Example1)",
      "miDebuggerServerAddress": "localhost:2346",
      "setupCommands": [
        {
          "description": "Enable pretty-printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}
